HTTP_PORT=3000

WINE_BINARY=wine
WINE64_BINARY=wine64
WINESERVER_BINARY=wineserver
DEFAULT_PREFIX_PATH=~/.blueberry/prefixes
WINE_DEBUG=-all

LOG_LEVEL=info
LOG_DIR=./wine/logs
LOG_MAX_FILES=10
LOG_MAX_SIZE=10m

PROCESS_CHECK_INTERVAL=5000
ZOMBIE_CLEANUP_INTERVAL=30000
MAX_PROCESSES=50

DISPLAY_MODE=browser
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=720
DISPLAY_DEPTH=24
DISPLAY_START=90
VNC_PORT_START=5900
XVFB_BINARY=Xvfb
X11VNC_BINARY=x11vnc